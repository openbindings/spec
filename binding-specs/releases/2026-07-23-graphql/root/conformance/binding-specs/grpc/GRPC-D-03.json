{
  "rule": "GRPC-D-03",
  "bindingSpec": "openbindings.grpc@1",
  "section": "7",
  "description": "`ref` is present and is `<fully-qualified-service>/<method>`: the service's protobuf fully-qualified name (package-qualified, or bare when its file declares no package), one `/`, and the unqualified RPC name, matched byte-exactly against the schema's declared services.",
  "notes": "Resolution-dependent tests always embed the schema as content, so the verdict is offline-decidable; verifying them requires a protobuf compiler, and a validator without one reports those tests unverified rather than passing or failing them. For a location-only source, resolution is checkable only against the live reflection listing and is fixtured here only as a grammar-valid positive.",
  "tests": [
    {
      "description": "package-qualified service and method resolving byte-exactly in the embedded schema",
      "document": {
        "openbindings": "0.2.0",
        "operations": { "getMenu": {} },
        "sources": {
          "shop": {
            "bindingSpec": "openbindings.grpc@1",
            "location": "api.example.com:443",
            "content": "syntax = \"proto3\";\npackage blend;\nservice CoffeeShop {\n  rpc GetMenu(MenuRequest) returns (Menu);\n}\nmessage MenuRequest {}\nmessage Menu {\n  repeated string items = 1;\n}\n"
          }
        },
        "bindings": {
          "getMenu.shop": {
            "operation": "getMenu",
            "source": "shop",
            "ref": "blend.CoffeeShop/GetMenu"
          }
        }
      },
      "valid": true
    },
    {
      "description": "bare service name for a schema whose file declares no package",
      "document": {
        "openbindings": "0.2.0",
        "operations": { "getMenu": {} },
        "sources": {
          "shop": {
            "bindingSpec": "openbindings.grpc@1",
            "location": "api.example.com:443",
            "content": "syntax = \"proto3\";\nservice CoffeeShop {\n  rpc GetMenu(MenuRequest) returns (Menu);\n}\nmessage MenuRequest {}\nmessage Menu {\n  repeated string items = 1;\n}\n"
          }
        },
        "bindings": {
          "getMenu.shop": {
            "operation": "getMenu",
            "source": "shop",
            "ref": "CoffeeShop/GetMenu"
          }
        }
      },
      "valid": true
    },
    {
      "description": "grammar-valid ref on a location-only source: resolution against live reflection is unverifiable offline, and the ref gives a validator nothing to refuse",
      "document": {
        "openbindings": "0.2.0",
        "operations": { "getMenu": {} },
        "sources": {
          "shop": {
            "bindingSpec": "openbindings.grpc@1",
            "location": "api.example.com:443"
          }
        },
        "bindings": {
          "getMenu.shop": {
            "operation": "getMenu",
            "source": "shop",
            "ref": "blend.CoffeeShop/GetMenu"
          }
        }
      },
      "valid": true
    },
    {
      "description": "ref is required: this family defines no whole-artifact invocation",
      "document": {
        "openbindings": "0.2.0",
        "operations": { "getMenu": {} },
        "sources": {
          "shop": {
            "bindingSpec": "openbindings.grpc@1",
            "location": "api.example.com:443"
          }
        },
        "bindings": {
          "getMenu.shop": { "operation": "getMenu", "source": "shop" }
        }
      },
      "valid": false,
      "violates": ["GRPC-D-03"]
    },
    {
      "description": "ref without the service/method separator",
      "document": {
        "openbindings": "0.2.0",
        "operations": { "getMenu": {} },
        "sources": {
          "shop": {
            "bindingSpec": "openbindings.grpc@1",
            "location": "api.example.com:443"
          }
        },
        "bindings": {
          "getMenu.shop": {
            "operation": "getMenu",
            "source": "shop",
            "ref": "blend.CoffeeShop"
          }
        }
      },
      "valid": false,
      "violates": ["GRPC-D-03"]
    },
    {
      "description": "empty method segment",
      "document": {
        "openbindings": "0.2.0",
        "operations": { "getMenu": {} },
        "sources": {
          "shop": {
            "bindingSpec": "openbindings.grpc@1",
            "location": "api.example.com:443"
          }
        },
        "bindings": {
          "getMenu.shop": {
            "operation": "getMenu",
            "source": "shop",
            "ref": "blend.CoffeeShop/"
          }
        }
      },
      "valid": false,
      "violates": ["GRPC-D-03"]
    },
    {
      "description": "empty service segment",
      "document": {
        "openbindings": "0.2.0",
        "operations": { "getMenu": {} },
        "sources": {
          "shop": {
            "bindingSpec": "openbindings.grpc@1",
            "location": "api.example.com:443"
          }
        },
        "bindings": {
          "getMenu.shop": {
            "operation": "getMenu",
            "source": "shop",
            "ref": "/GetMenu"
          }
        }
      },
      "valid": false,
      "violates": ["GRPC-D-03"]
    },
    {
      "description": "slash inside the service segment: a protobuf fully-qualified name is dot-separated, and the form carries exactly one /",
      "document": {
        "openbindings": "0.2.0",
        "operations": { "getMenu": {} },
        "sources": {
          "shop": {
            "bindingSpec": "openbindings.grpc@1",
            "location": "api.example.com:443",
            "content": "syntax = \"proto3\";\npackage blend;\nservice CoffeeShop {\n  rpc GetMenu(MenuRequest) returns (Menu);\n}\nmessage MenuRequest {}\nmessage Menu {\n  repeated string items = 1;\n}\n"
          }
        },
        "bindings": {
          "getMenu.shop": {
            "operation": "getMenu",
            "source": "shop",
            "ref": "blend/CoffeeShop/GetMenu"
          }
        }
      },
      "valid": false,
      "violates": ["GRPC-D-03"]
    },
    {
      "description": "matching is byte-exact, no case folding: getMenu does not match the declared GetMenu",
      "document": {
        "openbindings": "0.2.0",
        "operations": { "getMenu": {} },
        "sources": {
          "shop": {
            "bindingSpec": "openbindings.grpc@1",
            "location": "api.example.com:443",
            "content": "syntax = \"proto3\";\npackage blend;\nservice CoffeeShop {\n  rpc GetMenu(MenuRequest) returns (Menu);\n}\nmessage MenuRequest {}\nmessage Menu {\n  repeated string items = 1;\n}\n"
          }
        },
        "bindings": {
          "getMenu.shop": {
            "operation": "getMenu",
            "source": "shop",
            "ref": "blend.CoffeeShop/getMenu"
          }
        }
      },
      "valid": false,
      "violates": ["GRPC-D-03"]
    },
    {
      "description": "ref matching no method in the embedded schema makes the binding unresolvable",
      "document": {
        "openbindings": "0.2.0",
        "operations": { "listOrders": {} },
        "sources": {
          "shop": {
            "bindingSpec": "openbindings.grpc@1",
            "location": "api.example.com:443",
            "content": "syntax = \"proto3\";\npackage blend;\nservice CoffeeShop {\n  rpc GetMenu(MenuRequest) returns (Menu);\n}\nmessage MenuRequest {}\nmessage Menu {\n  repeated string items = 1;\n}\n"
          }
        },
        "bindings": {
          "listOrders.shop": {
            "operation": "listOrders",
            "source": "shop",
            "ref": "blend.CoffeeShop/ListOrders"
          }
        }
      },
      "valid": false,
      "violates": ["GRPC-D-03"]
    }
  ]
}
