{
  "format": "openbindings.binding-spec-processor-scenarios@1",
  "bindingSpec": "openbindings.asyncapi@1",
  "family": "asyncapi",
  "description": "Portable processor scenarios for AsyncAPI perspective, protocol-binding, complete-message framing, message selection, address derivation, encoding, reply, and credential boundaries.",
  "scenarios": [
    {
      "id": "ASYNC-PS-01",
      "rules": ["ASYNC-P-01"],
      "section": "3",
      "description": "AsyncAPI 2.x is refused loudly rather than interpreted through the 3.0 operation model.",
      "given": {
        "source": {
          "content": {
            "asyncapi": "2.6.0",
            "info": { "title": "Old", "version": "1" },
            "channels": {}
          }
        },
        "binding": { "ref": "#/operations/publish" },
        "invocation": { "inputPresent": true, "input": {} }
      },
      "expected": [
        {
          "disposition": "refusal",
          "phase": "load",
          "assertions": [{ "path": "/dispatch", "absent": true }]
        }
      ]
    },
    {
      "id": "ASYNC-PS-02",
      "rules": ["ASYNC-P-02"],
      "section": "8",
      "description": "An HTTP receive operation without an artifact-declared HTTP method refuses; POST is not inferred.",
      "given": {
        "source": {
          "content": {
            "asyncapi": "3.0.0",
            "info": { "title": "HTTP", "version": "1" },
            "servers": {
              "api": { "host": "api.example", "protocol": "https" }
            },
            "channels": {
              "tasks": {
                "address": "/tasks",
                "messages": {
                  "task": {
                    "contentType": "application/json",
                    "payload": { "type": "object" }
                  }
                }
              }
            },
            "operations": {
              "publish": {
                "action": "receive",
                "channel": { "$ref": "#/channels/tasks" },
                "messages": [{ "$ref": "#/channels/tasks/messages/task" }]
              }
            }
          }
        },
        "binding": { "ref": "#/operations/publish" },
        "invocation": { "inputPresent": true, "input": { "id": "1" } }
      },
      "expected": [
        {
          "disposition": "refusal",
          "phase": "resolution",
          "assertions": [{ "path": "/dispatch", "absent": true }]
        }
      ]
    },
    {
      "id": "ASYNC-PS-03",
      "rules": ["ASYNC-P-02"],
      "section": "8",
      "description": "A reply-bearing WebSocket receive operation is outside revision 1 and refuses rather than discarding declared replies.",
      "given": {
        "source": {
          "content": {
            "asyncapi": "3.0.0",
            "info": { "title": "WS reply", "version": "1" },
            "servers": {
              "socket": { "host": "events.example", "protocol": "wss" }
            },
            "channels": {
              "tasks": {
                "address": "/tasks",
                "messages": {
                  "request": { "contentType": "application/json" },
                  "answer": { "contentType": "application/json" }
                }
              }
            },
            "operations": {
              "publish": {
                "action": "receive",
                "channel": { "$ref": "#/channels/tasks" },
                "messages": [{ "$ref": "#/channels/tasks/messages/request" }],
                "reply": {
                  "messages": [{ "$ref": "#/channels/tasks/messages/answer" }]
                }
              }
            }
          }
        },
        "binding": { "ref": "#/operations/publish" },
        "invocation": { "inputPresent": true, "input": { "id": "1" } }
      },
      "expected": [
        {
          "disposition": "refusal",
          "phase": "resolution",
          "assertions": [{ "path": "/dispatch", "absent": true }]
        }
      ]
    },
    {
      "id": "ASYNC-PS-04",
      "rules": ["ASYNC-P-03", "ASYNC-P-04"],
      "section": "9.1",
      "description": "Several artifact-declared input messages require the message configuration point; payload sniffing does not choose one.",
      "given": {
        "source": {
          "content": {
            "asyncapi": "3.0.0",
            "info": { "title": "Messages", "version": "1" },
            "servers": {
              "api": { "host": "api.example", "protocol": "https" }
            },
            "channels": {
              "tasks": {
                "address": "/tasks",
                "messages": {
                  "json": { "contentType": "application/json" },
                  "text": { "contentType": "text/plain" }
                }
              }
            },
            "operations": {
              "publish": {
                "action": "receive",
                "channel": { "$ref": "#/channels/tasks" },
                "messages": [
                  { "$ref": "#/channels/tasks/messages/json" },
                  { "$ref": "#/channels/tasks/messages/text" }
                ],
                "bindings": { "http": { "method": "POST" } }
              }
            }
          }
        },
        "binding": { "ref": "#/operations/publish" },
        "invocation": { "inputPresent": true, "input": "hello" }
      },
      "expected": [
        {
          "disposition": "refusal",
          "phase": "pre-dispatch",
          "assertions": [{ "path": "/dispatch", "absent": true }]
        }
      ]
    },
    {
      "id": "ASYNC-PS-05",
      "rules": ["ASYNC-P-03", "ASYNC-P-04"],
      "section": "9.2",
      "description": "A selected message with no effective content type requires an explicit encode lane; the JSON value domain does not imply JSON wire encoding.",
      "given": {
        "source": {
          "content": {
            "asyncapi": "3.0.0",
            "info": { "title": "No media", "version": "1" },
            "servers": {
              "api": { "host": "api.example", "protocol": "https" }
            },
            "channels": {
              "tasks": {
                "address": "/tasks",
                "messages": { "task": { "payload": { "type": "object" } } }
              }
            },
            "operations": {
              "publish": {
                "action": "receive",
                "channel": { "$ref": "#/channels/tasks" },
                "messages": [{ "$ref": "#/channels/tasks/messages/task" }],
                "bindings": { "http": { "method": "POST" } }
              }
            }
          }
        },
        "binding": { "ref": "#/operations/publish" },
        "invocation": { "inputPresent": true, "input": { "id": "1" } }
      },
      "expected": [
        {
          "disposition": "refusal",
          "phase": "pre-dispatch",
          "assertions": [{ "path": "/dispatch", "absent": true }]
        }
      ]
    },
    {
      "id": "ASYNC-PS-06",
      "rules": ["ASYNC-P-04"],
      "section": "9.2",
      "description": "A required HTTP query field is supplied only through protocolFields and encoded on the request channel, not taken from the payload.",
      "given": {
        "source": {
          "content": {
            "asyncapi": "3.0.0",
            "info": { "title": "Query", "version": "1" },
            "servers": {
              "api": { "host": "api.example", "protocol": "https" }
            },
            "channels": {
              "tasks": {
                "address": "/tasks",
                "messages": { "task": { "contentType": "application/json" } }
              }
            },
            "operations": {
              "publish": {
                "action": "receive",
                "channel": { "$ref": "#/channels/tasks" },
                "messages": [{ "$ref": "#/channels/tasks/messages/task" }],
                "bindings": {
                  "http": {
                    "method": "POST",
                    "query": {
                      "type": "object",
                      "required": ["tenant"],
                      "properties": { "tenant": { "type": "string" } }
                    }
                  }
                }
              }
            }
          }
        },
        "binding": { "ref": "#/operations/publish" },
        "configuration": {
          "protocolFields": { "httpQuery": { "tenant": "acme" } }
        },
        "invocation": {
          "inputPresent": true,
          "input": { "tenant": "payload", "id": "1" }
        },
        "peer": { "status": 204, "body": "" }
      },
      "expected": [
        {
          "disposition": "complete",
          "phase": "completion",
          "assertions": [
            {
              "path": "/dispatch/url",
              "equals": "https://api.example/tasks?tenant=acme"
            },
            {
              "path": "/dispatch/body",
              "equals": { "tenant": "payload", "id": "1" }
            },
            { "path": "/outputs", "equals": [] }
          ]
        }
      ]
    },
    {
      "id": "ASYNC-PS-07",
      "rules": ["ASYNC-P-05", "ASYNC-P-06"],
      "section": "9.3",
      "description": "An exact HTTP reply status selects its declared message; a 201 final status is transport success and its JSON body is one output.",
      "given": {
        "source": {
          "content": {
            "asyncapi": "3.0.0",
            "info": { "title": "Reply", "version": "1" },
            "servers": {
              "api": { "host": "api.example", "protocol": "https" }
            },
            "channels": {
              "tasks": {
                "address": "/tasks",
                "messages": {
                  "task": { "contentType": "application/json" },
                  "created": {
                    "contentType": "application/json",
                    "bindings": { "http": { "statusCode": 201 } }
                  }
                }
              }
            },
            "operations": {
              "publish": {
                "action": "receive",
                "channel": { "$ref": "#/channels/tasks" },
                "messages": [{ "$ref": "#/channels/tasks/messages/task" }],
                "bindings": { "http": { "method": "POST" } },
                "reply": {
                  "messages": [{ "$ref": "#/channels/tasks/messages/created" }]
                }
              }
            }
          }
        },
        "binding": { "ref": "#/operations/publish" },
        "invocation": { "inputPresent": true, "input": { "id": "1" } },
        "peer": {
          "status": 201,
          "headers": { "Content-Type": "application/json" },
          "body": "{\"id\":\"1\",\"state\":\"created\"}"
        }
      },
      "expected": [
        {
          "disposition": "complete",
          "phase": "completion",
          "assertions": [
            {
              "path": "/outputs",
              "equals": [{ "id": "1", "state": "created" }]
            }
          ]
        }
      ]
    },
    {
      "id": "ASYNC-PS-08",
      "rules": ["ASYNC-P-06"],
      "section": "9.4",
      "description": "A declared reply body does not make a non-2xx HTTP publish successful; classification remains transport-native.",
      "given": {
        "source": {
          "content": {
            "asyncapi": "3.0.0",
            "info": { "title": "Failure", "version": "1" },
            "servers": {
              "api": { "host": "api.example", "protocol": "https" }
            },
            "channels": {
              "tasks": {
                "address": "/tasks",
                "messages": {
                  "task": { "contentType": "application/json" },
                  "problem": {
                    "contentType": "application/json",
                    "bindings": { "http": { "statusCode": 400 } }
                  }
                }
              }
            },
            "operations": {
              "publish": {
                "action": "receive",
                "channel": { "$ref": "#/channels/tasks" },
                "messages": [{ "$ref": "#/channels/tasks/messages/task" }],
                "bindings": { "http": { "method": "POST" } },
                "reply": {
                  "messages": [{ "$ref": "#/channels/tasks/messages/problem" }]
                }
              }
            }
          }
        },
        "binding": { "ref": "#/operations/publish" },
        "invocation": { "inputPresent": true, "input": { "id": "1" } },
        "peer": {
          "status": 400,
          "headers": { "Content-Type": "application/json" },
          "body": "{\"error\":\"bad\"}"
        }
      },
      "expected": [
        {
          "disposition": "error",
          "phase": "response",
          "assertions": [{ "path": "/outputs", "equals": [] }]
        }
      ]
    },
    {
      "id": "ASYNC-PS-09",
      "rules": ["ASYNC-P-07"],
      "section": "9.5",
      "description": "A WebSocket upgrade query credential colliding with a declared protocol field is refused rather than overwritten or duplicated.",
      "given": {
        "source": {
          "content": {
            "asyncapi": "3.0.0",
            "info": { "title": "WS security", "version": "1" },
            "servers": {
              "socket": {
                "host": "events.example",
                "protocol": "wss",
                "security": [
                  { "type": "httpApiKey", "in": "query", "name": "token" }
                ]
              }
            },
            "channels": {
              "events": {
                "address": "/events",
                "bindings": {
                  "ws": {
                    "query": {
                      "type": "object",
                      "properties": { "token": { "type": "string" } }
                    }
                  }
                },
                "messages": { "event": { "contentType": "application/json" } }
              }
            },
            "operations": {
              "subscribe": {
                "action": "send",
                "channel": { "$ref": "#/channels/events" },
                "messages": [{ "$ref": "#/channels/events/messages/event" }]
              }
            }
          }
        },
        "binding": { "ref": "#/operations/subscribe" },
        "configuration": {
          "protocolFields": { "webSocketQuery": { "token": "field" } }
        },
        "invocation": { "inputPresent": false },
        "runtime": { "credentials": { "token": "credential" } }
      },
      "expected": [
        {
          "disposition": "refusal",
          "phase": "pre-dispatch",
          "assertions": [{ "path": "/dispatch", "absent": true }]
        }
      ]
    },
    {
      "id": "ASYNC-PS-10",
      "rules": ["ASYNC-P-03", "ASYNC-P-05"],
      "section": "9.3",
      "description": "A fragmented WebSocket data message is reassembled and decoded once; frame boundaries never create outputs.",
      "given": {
        "source": {
          "content": {
            "asyncapi": "3.0.0",
            "info": { "title": "Fragmentation", "version": "1" },
            "servers": {
              "socket": { "host": "events.example", "protocol": "wss" }
            },
            "channels": {
              "events": {
                "address": "/events",
                "messages": { "event": { "contentType": "application/json" } }
              }
            },
            "operations": {
              "subscribe": {
                "action": "send",
                "channel": { "$ref": "#/channels/events" },
                "messages": [{ "$ref": "#/channels/events/messages/event" }]
              }
            }
          }
        },
        "binding": { "ref": "#/operations/subscribe" },
        "invocation": { "inputPresent": false },
        "peer": {
          "webSocketMessages": [
            { "opcode": "text", "fragments": ["{\"id\":", "\"1\"}"] }
          ],
          "cleanClose": true
        }
      },
      "expected": [
        {
          "disposition": "complete",
          "phase": "completion",
          "assertions": [{ "path": "/outputs", "equals": [{ "id": "1" }] }]
        }
      ]
    },
    {
      "id": "ASYNC-PS-11",
      "rules": ["ASYNC-P-04"],
      "section": "9.2",
      "description": "A WebSocket publish requires an explicit text-or-binary message choice because the artifact binding does not define the opcode.",
      "given": {
        "source": {
          "content": {
            "asyncapi": "3.0.0",
            "info": { "title": "Opcode", "version": "1" },
            "servers": {
              "socket": { "host": "events.example", "protocol": "wss" }
            },
            "channels": {
              "events": {
                "address": "/events",
