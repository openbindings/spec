    {
      "id": "ASYNC-PS-16",
      "rules": ["ASYNC-P-07"],
      "section": "9.5",
      "description": "An HTTP API-key credential cannot replace the processor-owned Content-Type field selected by the message's declared media type.",
      "given": {
        "source": {
          "content": {
            "asyncapi": "3.0.0",
            "info": { "title": "secure publish", "version": "1" },
            "servers": {
              "prod": {
                "host": "api.example",
                "protocol": "https",
                "security": [{ "$ref": "#/components/securitySchemes/key" }]
              }
            },
            "channels": {
              "commands": {
                "address": "/commands",
                "messages": {
                  "command": {
                    "contentType": "application/json",
                    "payload": { "type": "object" }
                  }
                }
              }
            },
            "operations": {
              "publish": {
                "action": "receive",
                "channel": { "$ref": "#/channels/commands" },
                "messages": [
                  { "$ref": "#/channels/commands/messages/command" }
                ],
                "bindings": {
                  "http": {
                    "method": "POST",
                    "bindingVersion": "0.3.0"
                  }
                }
              }
            },
            "components": {
              "securitySchemes": {
                "key": {
                  "type": "httpApiKey",
                  "in": "header",
                  "name": "Content-Type"
                }
              }
            }
          }
        },
        "binding": { "ref": "#/operations/publish" },
        "invocation": { "inputPresent": true, "input": { "id": 1 } },
        "runtime": { "credentials": { "key": "secret" } }
      },
      "expected": [
        {
          "disposition": "refusal",
          "phase": "pre-dispatch",
          "assertions": [{ "path": "/dispatch", "absent": true }]
        }
      ]
    },
    {
      "id": "ASYNC-PS-17",
      "rules": ["ASYNC-P-05"],
      "section": "9.3",
      "description": "Two parameterized HTTP reply media declarations tying at the greatest match specificity are a protocol error, not message-list precedence.",
      "given": {
        "source": {
          "content": {
            "asyncapi": "3.0.0",
