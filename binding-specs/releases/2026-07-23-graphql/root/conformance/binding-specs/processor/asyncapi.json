          "assertions": [{ "path": "/dispatch", "absent": true }]
        }
      ]
    },
    {
      "id": "ASYNC-PS-14",
      "rules": ["ASYNC-P-04"],
      "section": "9.2",
      "description": "An address parameter location derives from the outgoing payload and is percent-encoded as one path-segment value.",
      "given": {
        "source": {
          "content": {
            "asyncapi": "3.0.0",
            "info": { "title": "Runtime address", "version": "1" },
            "servers": {
              "api": { "host": "api.example", "protocol": "https" }
            },
            "channels": {
              "events": {
                "address": "/tenants/{tenant}/events",
                "parameters": {
                  "tenant": {
                    "location": "$message.payload#/tenant",
                    "schema": { "type": "string" }
                  }
                },
                "messages": { "event": { "contentType": "application/json" } }
              }
            },
            "operations": {
              "publish": {
                "action": "receive",
                "channel": { "$ref": "#/channels/events" },
                "messages": [{ "$ref": "#/channels/events/messages/event" }],
                "bindings": { "http": { "method": "POST" } }
              }
            }
          }
        },
        "binding": { "ref": "#/operations/publish" },
        "invocation": {
          "inputPresent": true,
          "input": { "tenant": "a/b", "id": "1" }
        },
        "peer": { "status": 204, "body": "" }
      },
      "expected": [
        {
          "disposition": "complete",
          "phase": "completion",
          "assertions": [
            {
              "path": "/dispatch/url",
              "equals": "https://api.example/tenants/a%2Fb/events"
            },
            {
              "path": "/dispatch/body",
              "equals": { "tenant": "a/b", "id": "1" }
            },
            { "path": "/outputs", "equals": [] }
          ]
        }
      ]
    },
    {
