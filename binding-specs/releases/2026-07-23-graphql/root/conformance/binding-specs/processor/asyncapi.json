              }
            },
            "operations": {
              "publish": {
                "action": "receive",
                "channel": { "$ref": "#/channels/events" },
                "messages": [{ "$ref": "#/channels/events/messages/event" }]
              }
            }
          }
        },
        "binding": { "ref": "#/operations/publish" },
        "invocation": { "inputPresent": true, "input": { "id": "1" } }
      },
      "expected": [
        {
          "disposition": "refusal",
          "phase": "pre-dispatch",
          "assertions": [{ "path": "/dispatch", "absent": true }]
        }
      ]
    },
    {
      "id": "ASYNC-PS-12",
      "rules": ["ASYNC-P-04", "ASYNC-P-05"],
      "section": "9.3",
      "description": "Conflicting WebSocket subscription content types are refused even when decode configuration attempts to choose a lane.",
      "given": {
        "source": {
          "content": {
            "asyncapi": "3.0.0",
            "info": { "title": "Ambiguous subscription", "version": "1" },
            "servers": {
              "socket": { "host": "events.example", "protocol": "wss" }
            },
            "channels": {
              "events": {
                "address": "/events",
                "messages": {
                  "json": { "contentType": "application/json" },
                  "text": { "contentType": "text/plain" }
                }
              }
            },
            "operations": {
              "subscribe": {
                "action": "send",
                "channel": { "$ref": "#/channels/events" },
                "messages": [
                  { "$ref": "#/channels/events/messages/json" },
                  { "$ref": "#/channels/events/messages/text" }
                ]
              }
            }
          }
        },
        "binding": { "ref": "#/operations/subscribe" },
        "configuration": { "decode": "json" },
        "invocation": { "inputPresent": false }
      },
      "expected": [
        {
          "disposition": "refusal",
          "phase": "resolution",
          "assertions": [{ "path": "/dispatch", "absent": true }]
        }
      ]
    },
    {
      "id": "ASYNC-PS-13",
      "rules": ["ASYNC-P-02"],
      "section": "2",
      "description": "An explicitly different WebSockets binding version is outside the frozen revision-1 envelope.",
      "given": {
        "source": {
          "content": {
            "asyncapi": "3.0.0",
            "info": { "title": "Binding version", "version": "1" },
            "servers": {
              "socket": { "host": "events.example", "protocol": "wss" }
            },
            "channels": {
              "events": {
                "address": "/events",
                "bindings": { "ws": { "bindingVersion": "0.2.0" } },
                "messages": { "event": { "contentType": "application/json" } }
              }
