{
  "format": "openbindings.binding-spec-processor-scenarios@1",
  "bindingSpec": "openbindings.graphql@1",
  "family": "graphql",
  "description": "Portable GraphQL processor scenarios for whole-variable input, required interpretation points, root-field integrity, explicit protocol fields, response-envelope preservation, media-aware HTTP classification, pinned introspection, and graphql-transport-ws streaming.",
  "scenarios": [
    {
      "id": "GQL-PS-01",
      "rules": ["GQL-P-01"],
      "section": "9.1",
      "description": "A supplied caller object is carried wholesale as variables; unknown-to-the-root keys are not filtered and no _query field is consumed specially.",
      "given": {
        "source": {
          "location": "https://api.example.test/graphql",
          "content": {
            "data": {
              "__schema": {
                "queryType": { "name": "RootQuery" },
                "mutationType": null,
                "subscriptionType": null,
                "types": [
                  {
                    "kind": "OBJECT",
                    "name": "RootQuery",
                    "fields": [
                      {
                        "name": "viewer",
                        "args": [
                          {
                            "name": "id",
                            "type": {
                              "kind": "NON_NULL",
                              "name": null,
                              "ofType": { "kind": "SCALAR", "name": "ID", "ofType": null }
                            }
                          }
                        ],
                        "type": { "kind": "SCALAR", "name": "String", "ofType": null },
                        "isDeprecated": false
                      }
                    ]
                  },
                  { "kind": "SCALAR", "name": "ID" },
                  { "kind": "SCALAR", "name": "String" }
                ]
              }
            }
          }
        },
        "binding": { "ref": "query/viewer" },
        "configuration": {
          "document": {
            "source": "query Viewer($id: ID!) { viewer(id: $id) }",
            "operationName": "Viewer"
          }
        },
        "invocation": {
          "inputPresent": true,
          "input": { "id": "u-1", "unused": 7, "_query": "not metadata" }
        },
        "peer": {
          "status": 200,
          "contentType": "application/graphql-response+json",
          "body": { "data": { "viewer": "Ada" } }
        }
      },
      "expected": [
        {
          "disposition": "complete",
          "phase": "completion",
          "assertions": [
            {
              "path": "/dispatch/body/variables",
              "equals": { "id": "u-1", "unused": 7, "_query": "not metadata" }
            },
            {
              "path": "/dispatch/body/query",
              "equals": "query Viewer($id: ID!) { viewer(id: $id) }"
            }
          ]
        }
      ]
    },
    {
      "id": "GQL-PS-02",
      "rules": ["GQL-P-01"],
      "section": "9.1",
      "description": "Absent caller input omits the variables member rather than manufacturing an empty object.",
      "given": {
        "source": {
          "location": "https://api.example.test/graphql",
          "content": {
            "data": {
              "__schema": {
                "queryType": { "name": "RootQuery" },
                "mutationType": null,
                "subscriptionType": null,
                "types": [
                  {
                    "kind": "OBJECT",
                    "name": "RootQuery",
                    "fields": [
                      {
                        "name": "ping",
                        "args": [],
                        "type": { "kind": "SCALAR", "name": "String", "ofType": null },
                        "isDeprecated": false
                      }
                    ]
                  },
                  { "kind": "SCALAR", "name": "String" }
                ]
              }
            }
          }
        },
        "binding": { "ref": "query/ping" },
        "configuration": {
          "document": { "source": "query { ping }" }
        },
        "invocation": { "inputPresent": false },
        "peer": {
          "status": 200,
          "contentType": "application/graphql-response+json",
          "body": { "data": { "ping": "pong" } }
        }
      },
      "expected": [
        {
          "disposition": "complete",
          "phase": "completion",
          "assertions": [
            { "path": "/dispatch/body/variables", "absent": true }
          ]
        }
      ]
    },
    {
      "id": "GQL-PS-03",
      "rules": ["GQL-P-02"],
      "section": "9.2",
      "description": "The schema cannot determine a selection set, so a missing document interpretation produces a resolvable context challenge before introspection or dispatch.",
      "given": {
        "source": { "location": "https://api.example.test/graphql" },
        "binding": { "ref": "query/viewer" },
        "invocation": { "inputPresent": false }
      },
      "expected": [
        {
          "disposition": "context-required",
          "phase": "pre-dispatch",
          "assertions": [
            { "path": "/context/alternatives/0/requirements/0/type", "equals": "config.value" },
            { "path": "/context/alternatives/0/requirements/0/point", "equals": "document" },
            { "path": "/introspectionRequests", "equals": [] },
            { "path": "/dispatch", "absent": true }
          ]
        }
      ]
    },
    {
      "id": "GQL-PS-04",
      "rules": ["GQL-P-02", "GQL-P-05"],
      "section": "8",
      "description": "A configured document selecting a different root field than the binding ref is refused before dispatch after resolving the root against the pinned schema.",
      "given": {
        "source": {
          "location": "https://api.example.test/graphql",
          "content": {
            "data": {
              "__schema": {
                "queryType": { "name": "RootQuery" },
                "mutationType": null,
                "subscriptionType": null,
                "types": [
                  {
                    "kind": "OBJECT",
                    "name": "RootQuery",
                    "fields": [
                      {
                        "name": "viewer",
                        "args": [],
                        "type": { "kind": "SCALAR", "name": "String", "ofType": null },
                        "isDeprecated": false
                      },
                      {
                        "name": "health",
                        "args": [],
                        "type": { "kind": "SCALAR", "name": "String", "ofType": null },
                        "isDeprecated": false
                      }
                    ]
                  },
                  { "kind": "SCALAR", "name": "String" }
                ]
              }
            }
          }
        },
        "binding": { "ref": "query/viewer" },
        "configuration": {
          "document": { "source": "query { health }" }
        },
        "invocation": { "inputPresent": false }
      },
      "expected": [
        {
          "disposition": "refusal",
          "phase": "pre-dispatch",
          "assertions": [
            { "path": "/introspectionRequests", "equals": [] },
            { "path": "/dispatch", "absent": true }
          ]
        }
      ]
    },
    {
      "id": "GQL-PS-05",
      "rules": ["GQL-P-02"],
      "section": "9.2",
      "description": "A configured header that collides case-insensitively with the processor-owned Content-Type field is refused rather than assigned precedence.",
      "given": {
        "source": {
          "location": "https://api.example.test/graphql",
          "content": {
            "data": {
              "__schema": {
                "queryType": { "name": "RootQuery" },
                "mutationType": null,
                "subscriptionType": null,
                "types": [
                  {
                    "kind": "OBJECT",
                    "name": "RootQuery",
                    "fields": [
                      {
                        "name": "ping",
                        "args": [],
                        "type": { "kind": "SCALAR", "name": "String", "ofType": null },
                        "isDeprecated": false
                      }
                    ]
                  },
                  { "kind": "SCALAR", "name": "String" }
                ]
              }
            }
          }
        },
        "binding": { "ref": "query/ping" },
        "configuration": {
          "document": { "source": "query { ping }" },
          "protocolFields": {
            "httpHeaders": { "content-TYPE": "text/plain" }
          }
        },
        "invocation": { "inputPresent": false }
      },
      "expected": [
        {
          "disposition": "refusal",
          "phase": "pre-dispatch",
          "assertions": [
            { "path": "/dispatch", "absent": true }
          ]
        }
      ]
    },
    {
      "id": "GQL-PS-06",
      "rules": ["GQL-P-03"],
      "section": "9.3",
      "description": "A well-formed application/graphql-response+json request-error result remains one complete in-band output even with HTTP 400.",
      "given": {
        "source": {
          "location": "https://api.example.test/graphql",
          "content": {
            "data": {
              "__schema": {
                "queryType": { "name": "RootQuery" },
                "mutationType": null,
                "subscriptionType": null,
                "types": [
                  {
                    "kind": "OBJECT",
                    "name": "RootQuery",
                    "fields": [
                      {
                        "name": "viewer",
                        "args": [],
                        "type": { "kind": "SCALAR", "name": "String", "ofType": null },
                        "isDeprecated": false
                      }
                    ]
                  },
                  { "kind": "SCALAR", "name": "String" }
                ]
              }
            }
          }
        },
        "binding": { "ref": "query/viewer" },
        "configuration": {
          "document": { "source": "query { viewer }" }
        },
        "invocation": { "inputPresent": false },
        "peer": {
          "status": 400,
          "contentType": "application/graphql-response+json; charset=utf-8",
          "body": {
            "errors": [
              { "message": "request rejected", "extensions": { "code": "BAD_REQUEST" } }
            ]
          }
        }
      },
      "expected": [
        {
          "disposition": "complete",
          "phase": "completion",
          "assertions": [
            {
              "path": "/outputs",
              "equals": [
                {
                  "errors": [
                    { "message": "request rejected", "extensions": { "code": "BAD_REQUEST" } }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "GQL-PS-07",
      "rules": ["GQL-P-03"],
      "section": "9.3",
      "description": "The legacy application/json lane does not trust a non-2xx body as a GraphQL output.",
      "given": {
        "source": {
          "location": "https://api.example.test/graphql",
          "content": {
            "data": {
              "__schema": {
                "queryType": { "name": "RootQuery" },
                "mutationType": null,
                "subscriptionType": null,
                "types": [
                  {
                    "kind": "OBJECT",
                    "name": "RootQuery",
                    "fields": [
                      {
                        "name": "viewer",
                        "args": [],
                        "type": { "kind": "SCALAR", "name": "String", "ofType": null },
                        "isDeprecated": false
                      }
                    ]
                  },
                  { "kind": "SCALAR", "name": "String" }
                ]
              }
            }
          }
        },
        "binding": { "ref": "query/viewer" },
        "configuration": {
          "document": { "source": "query { viewer }" }
        },
        "invocation": { "inputPresent": false },
        "peer": {
          "status": 400,
          "contentType": "application/json",
          "body": { "errors": [{ "message": "request rejected" }] }
        }
      },
      "expected": [
        {
          "disposition": "error",
          "phase": "response",
          "assertions": [
            { "path": "/outputs", "equals": [] }
          ]
        }
      ]
    },
    {
      "id": "GQL-PS-08",
      "rules": ["GQL-P-03", "GQL-P-04"],
      "section": "9.4",
      "description": "graphql-transport-ws next payloads remain complete GraphQL response values, including in-band errors, and complete ends normally.",
      "given": {
        "source": {
          "location": "https://api.example.test/graphql",
          "content": {
            "data": {
              "__schema": {
                "queryType": { "name": "RootQuery" },
                "mutationType": null,
                "subscriptionType": { "name": "RootSubscription" },
                "types": [
                  { "kind": "OBJECT", "name": "RootQuery", "fields": [] },
                  {
                    "kind": "OBJECT",
                    "name": "RootSubscription",
                    "fields": [
                      {
                        "name": "updates",
                        "args": [],
                        "type": { "kind": "SCALAR", "name": "String", "ofType": null },
                        "isDeprecated": false
                      }
                    ]
                  },
                  { "kind": "SCALAR", "name": "String" }
                ]
              }
            }
          }
        },
        "binding": { "ref": "subscription/updates" },
        "configuration": {
          "document": { "source": "subscription Watch { updates }", "operationName": "Watch" },
          "subscriptionTarget": "wss://stream.example.test/graphql",
          "protocolFields": { "connectionInitPayload": { "tenant": "demo" } }
        },
        "invocation": { "inputPresent": false },
        "peer": {
          "messages": [
            { "type": "connection_ack" },
            {
              "type": "next",
              "id": "1",
              "payload": {
                "data": { "updates": null },
                "errors": [{ "message": "resolver warning" }]
              }
            },
            { "type": "complete", "id": "1" }
          ]
        }
      },
      "expected": [
        {
          "disposition": "complete",
          "phase": "completion",
          "assertions": [
            { "path": "/dispatch/target", "equals": "wss://stream.example.test/graphql" },
            { "path": "/dispatch/connectionInit/payload", "equals": { "tenant": "demo" } },
            {
              "path": "/outputs",
              "equals": [
                {
                  "data": { "updates": null },
                  "errors": [{ "message": "resolver warning" }]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "GQL-PS-09",
      "rules": ["GQL-P-04"],
      "section": "9.4",
      "description": "A protocol error after a next payload fails the subscription without retracting the already emitted response.",
      "given": {
        "source": {
          "location": "https://api.example.test/graphql",
          "content": {
            "data": {
              "__schema": {
                "queryType": { "name": "RootQuery" },
                "mutationType": null,
                "subscriptionType": { "name": "RootSubscription" },
                "types": [
                  { "kind": "OBJECT", "name": "RootQuery", "fields": [] },
                  {
                    "kind": "OBJECT",
                    "name": "RootSubscription",
                    "fields": [
                      {
                        "name": "updates",
                        "args": [],
                        "type": { "kind": "SCALAR", "name": "String", "ofType": null },
                        "isDeprecated": false
                      }
                    ]
                  },
                  { "kind": "SCALAR", "name": "String" }
                ]
              }
            }
          }
        },
        "binding": { "ref": "subscription/updates" },
        "configuration": {
          "document": { "source": "subscription { updates }" },
          "subscriptionTarget": "wss://stream.example.test/graphql"
        },
        "invocation": { "inputPresent": false },
        "peer": {
          "messages": [
            { "type": "connection_ack" },
            { "type": "next", "id": "1", "payload": { "data": { "updates": "one" } } },
            { "type": "error", "id": "1", "payload": [{ "message": "stopped" }] }
          ]
        }
      },
      "expected": [
        {
          "disposition": "error",
          "phase": "completion",
          "assertions": [
            { "path": "/outputs", "equals": [{ "data": { "updates": "one" } }] }
          ]
        }
      ]
    },
    {
      "id": "GQL-PS-10",
      "rules": ["GQL-P-05"],
      "section": "3",
      "description": "Pinned content displaces live introspection completely; processors never refresh or supplement it from the service.",
      "given": {
        "source": {
          "location": "https://api.example.test/graphql",
          "content": {
            "data": {
              "__schema": {
                "queryType": { "name": "RootQuery" },
                "mutationType": null,
                "subscriptionType": null,
                "types": [
                  {
                    "kind": "OBJECT",
                    "name": "RootQuery",
                    "fields": [
                      {
                        "name": "ping",
                        "args": [],
                        "type": { "kind": "SCALAR", "name": "String", "ofType": null },
                        "isDeprecated": false
                      }
                    ]
                  },
                  { "kind": "SCALAR", "name": "String" }
                ]
              }
            }
          }
        },
        "binding": { "ref": "query/ping" },
        "configuration": {
          "document": { "source": "query { ping }" }
        },
        "invocation": { "inputPresent": false },
        "peer": {
          "status": 200,
          "contentType": "application/graphql-response+json",
          "body": { "data": { "ping": "pong" } }
        }
      },
      "expected": [
        {
          "disposition": "complete",
          "phase": "completion",
          "assertions": [
            { "path": "/introspectionRequests", "equals": [] },
            { "path": "/outputs", "equals": [{ "data": { "ping": "pong" } }] }
          ]
        }
      ]
    },
    {
      "id": "GQL-PS-11",
      "rules": ["GQL-P-02"],
      "section": "9.2",
      "description": "A generic credential whose GraphQL protocol location is unnamed is refused before dispatch rather than ignored or mapped to a preferred header.",
      "given": {
        "source": {
          "location": "https://api.example.test/graphql",
          "content": {
            "data": {
              "__schema": {
                "queryType": { "name": "RootQuery" },
                "mutationType": null,
                "subscriptionType": null,
                "types": [
                  {
                    "kind": "OBJECT",
                    "name": "RootQuery",
                    "fields": [
                      {
                        "name": "ping",
                        "args": [],
                        "type": { "kind": "SCALAR", "name": "String", "ofType": null },
                        "isDeprecated": false
                      }
                    ]
                  },
                  { "kind": "SCALAR", "name": "String" }
                ]
              }
            }
          }
        },
        "binding": { "ref": "query/ping" },
        "configuration": {
          "document": { "source": "query { ping }" }
        },
        "invocation": { "inputPresent": false },
        "runtime": {
          "credentials": { "bearerToken": "ambiguous" }
        }
      },
      "expected": [
        {
          "disposition": "refusal",
          "phase": "pre-dispatch",
          "assertions": [
            { "path": "/introspectionRequests", "equals": [] },
            { "path": "/dispatch", "absent": true }
          ]
        }
      ]
    }
  ]
}
