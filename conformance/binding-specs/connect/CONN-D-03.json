{
  "rule": "CONN-D-03",
  "bindingSpec": "openbindings.connect@1",
  "section": "7",
  "description": "`ref` is present and is `<fully-qualified-service>/<method>` (exactly `openbindings.grpc@1` §7's grammar, incorporated), matched byte-exactly in schema mode. In descriptorless mode the segments ride verbatim into the request URL and there is nothing to resolve against.",
  "notes": "Schema-mode resolution tests embed the schema as content; verifying them requires a protobuf compiler, and a validator without one reports those tests unverified rather than passing or failing them. Descriptorless-mode positives pin that an unresolvable-at-the-server ref is that mode's stated limit, not a document defect.",
  "tests": [
    {
      "description": "schema mode: package-qualified service and method resolving byte-exactly in the embedded schema",
      "document": {
        "openbindings": "0.2.0",
        "operations": { "getMenu": {} },
        "sources": {
          "shop": {
            "bindingSpec": "openbindings.connect@1",
            "location": "https://api.example.com",
            "content": "syntax = \"proto3\";\npackage blend;\nservice CoffeeShop {\n  rpc GetMenu(MenuRequest) returns (Menu);\n}\nmessage MenuRequest {}\nmessage Menu {\n  repeated string items = 1;\n}\n"
          }
        },
        "bindings": {
          "getMenu.shop": {
            "operation": "getMenu",
            "source": "shop",
            "ref": "blend.CoffeeShop/GetMenu"
          }
        }
      },
      "valid": true
    },
    {
      "description": "descriptorless mode: grammar-valid ref on a location-only source rides verbatim into the request URL",
      "document": {
        "openbindings": "0.2.0",
        "operations": { "echo": {} },
        "sources": {
          "svc": {
            "bindingSpec": "openbindings.connect@1",
            "location": "https://api.example.com"
          }
        },
        "bindings": {
          "echo.svc": {
            "operation": "echo",
            "source": "svc",
            "ref": "demo.EchoService/Echo"
          }
        }
      },
      "valid": true
    },
    {
      "description": "ref is required: this family defines no whole-artifact invocation",
      "document": {
        "openbindings": "0.2.0",
        "operations": { "echo": {} },
        "sources": {
          "svc": {
            "bindingSpec": "openbindings.connect@1",
            "location": "https://api.example.com"
          }
        },
        "bindings": {
          "echo.svc": { "operation": "echo", "source": "svc" }
        }
      },
      "valid": false,
      "violates": ["CONN-D-03"]
    },
    {
      "description": "ref without the service/method separator",
      "document": {
        "openbindings": "0.2.0",
        "operations": { "echo": {} },
        "sources": {
          "svc": {
            "bindingSpec": "openbindings.connect@1",
            "location": "https://api.example.com"
          }
        },
        "bindings": {
          "echo.svc": {
            "operation": "echo",
            "source": "svc",
            "ref": "demo.EchoService"
          }
        }
      },
      "valid": false,
      "violates": ["CONN-D-03"]
    },
    {
      "description": "empty method segment",
      "document": {
        "openbindings": "0.2.0",
        "operations": { "echo": {} },
        "sources": {
          "svc": {
            "bindingSpec": "openbindings.connect@1",
            "location": "https://api.example.com"
          }
        },
        "bindings": {
          "echo.svc": {
            "operation": "echo",
            "source": "svc",
            "ref": "demo.EchoService/"
          }
        }
      },
      "valid": false,
      "violates": ["CONN-D-03"]
    },
    {
      "description": "schema mode: matching is byte-exact, and a case-mismatched method makes the binding unresolvable",
      "document": {
        "openbindings": "0.2.0",
        "operations": { "getMenu": {} },
        "sources": {
          "shop": {
            "bindingSpec": "openbindings.connect@1",
            "location": "https://api.example.com",
            "content": "syntax = \"proto3\";\npackage blend;\nservice CoffeeShop {\n  rpc GetMenu(MenuRequest) returns (Menu);\n}\nmessage MenuRequest {}\nmessage Menu {\n  repeated string items = 1;\n}\n"
          }
        },
        "bindings": {
          "getMenu.shop": {
            "operation": "getMenu",
            "source": "shop",
            "ref": "blend.CoffeeShop/getMenu"
          }
        }
      },
      "valid": false,
      "violates": ["CONN-D-03"]
    }
  ]
}
