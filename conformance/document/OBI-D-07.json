{
  "rule": "OBI-D-07",
  "section": "10.2",
  "description": "Has no $vocabulary keyword in any schema within the document.",
  "notes": "Recursive enforcement: $vocabulary is forbidden at any nesting depth, not only at the top level of a schema. Per §10.2, the spec's JSON Schema artifact only enforces this at top level; recursive enforcement is an implementer obligation under OBI-D-07 prose.",
  "tests": [
    {
      "description": "schemas with no $vocabulary anywhere",
      "document": {
        "openbindings": "0.2.0",
        "schemas": {
          "Task": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              }
            }
          }
        },
        "operations": {
          "createTask": {}
        }
      },
      "valid": true
    },
    {
      "description": "top-level schema declares $vocabulary",
      "document": {
        "openbindings": "0.2.0",
        "schemas": {
          "Task": {
            "$vocabulary": {
              "https://json-schema.org/draft/2020-12/vocab/core": true
            },
            "type": "object"
          }
        },
        "operations": {
          "createTask": {}
        }
      },
      "valid": false,
      "violates": [
        "OBI-D-07"
      ]
    },
    {
      "description": "operation input schema declares $vocabulary",
      "document": {
        "openbindings": "0.2.0",
        "operations": {
          "createTask": {
            "input": {
              "$vocabulary": {
                "https://json-schema.org/draft/2020-12/vocab/core": true
              },
              "type": "object"
            }
          }
        }
      },
      "valid": false,
      "violates": [
        "OBI-D-07"
      ]
    },
    {
      "description": "$vocabulary in a nested property subschema",
      "document": {
        "openbindings": "0.2.0",
        "schemas": {
          "Task": {
            "type": "object",
            "properties": {
              "metadata": {
                "$vocabulary": {
                  "https://json-schema.org/draft/2020-12/vocab/core": true
                },
                "type": "object"
              }
            }
          }
        },
        "operations": {
          "createTask": {}
        }
      },
      "valid": false,
      "violates": [
        "OBI-D-07"
      ]
    },
    {
      "description": "$vocabulary in a $defs subschema",
      "document": {
        "openbindings": "0.2.0",
        "schemas": {
          "Task": {
            "type": "object",
            "$defs": {
              "Inner": {
                "$vocabulary": {
                  "https://json-schema.org/draft/2020-12/vocab/core": true
                },
                "type": "string"
              }
            }
          }
        },
        "operations": {
          "createTask": {}
        }
      },
      "valid": false,
      "violates": [
        "OBI-D-07"
      ]
    },
    {
      "description": "a property NAMED $vocabulary under `properties` is schema content, not the keyword (keyword-position-aware walking; a grep-style walker false-positives here)",
      "document": {
        "openbindings": "0.2.0",
        "operations": {
          "getMeta": {
            "output": {
              "type": "object",
              "properties": {
                "$vocabulary": {
                  "type": "object"
                },
                "$schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "valid": true
    }
  ]
}
