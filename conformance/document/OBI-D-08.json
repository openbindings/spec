{
  "rule": "OBI-D-08",
  "section": "10.2",
  "description": "Has every bindings[*].operation value present as a key in the document's operations map.",
  "tests": [
    {
      "description": "binding references an existing operation key",
      "document": {
        "openbindings": "0.2.0",
        "operations": {
          "createTask": {}
        },
        "sources": {
          "httpApi": {
            "bindingSpec": "openbindings.openapi@1",
            "location": "https://api.example.com/openapi.json"
          }
        },
        "bindings": {
          "createTask.http": {
            "operation": "createTask",
            "source": "httpApi"
          }
        }
      },
      "valid": true
    },
    {
      "description": "binding references a non-existent operation key",
      "document": {
        "openbindings": "0.2.0",
        "operations": {
          "createTask": {}
        },
        "sources": {
          "httpApi": {
            "bindingSpec": "openbindings.openapi@1",
            "location": "https://api.example.com/openapi.json"
          }
        },
        "bindings": {
          "createTask.http": {
            "operation": "nonexistentOp",
            "source": "httpApi"
          }
        }
      },
      "valid": false,
      "violates": [
        "OBI-D-08"
      ]
    },
    {
      "description": "binding references operation \"constructor\", a valid OBI-D-03 identifier that is also a built-in object property name, with no such operation defined (guards against an implementation resolving the reference through a language object's prototype chain rather than the document's own map)",
      "document": {
        "openbindings": "0.2.0",
        "operations": {
          "createTask": {}
        },
        "sources": {
          "httpApi": {
            "bindingSpec": "openbindings.openapi@1",
            "location": "https://api.example.com/openapi.json"
          }
        },
        "bindings": {
          "createTask.http": {
            "operation": "constructor",
            "source": "httpApi"
          }
        }
      },
      "valid": false,
      "violates": [
        "OBI-D-08"
      ]
    },
    {
      "description": "binding operation value matches an alias rather than a key in the operations map",
      "document": {
        "openbindings": "0.2.0",
        "operations": {
          "createTask": {
            "aliases": [
              "addTask"
            ]
          }
        },
        "sources": {
          "httpApi": {
            "bindingSpec": "openbindings.openapi@1",
            "location": "https://api.example.com/openapi.json"
          }
        },
        "bindings": {
          "addTask.http": {
            "operation": "addTask",
            "source": "httpApi"
          }
        }
      },
      "valid": false,
      "violates": [
        "OBI-D-08"
      ]
    }
  ]
}
