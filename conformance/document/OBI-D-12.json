{
  "rule": "OBI-D-12",
  "section": "10.2",
  "description": "Has an openbindings field whose value is a valid Semantic Versioning 2.0.0 string.",
  "notes": "Pre-release openbindings values are not exercised as positive cases here: per §8.1 a tool refuses a pre-release it does not declare support for (OBI-T-04), so a pre-release document is not globally valid even though the pre-release syntax is valid SemVer 2.0.0. SemVer's acceptance of pre-release syntax is covered at the SDK unit level. The leading-zero pre-release case below is a negative SemVer-pattern test and is unaffected.",
  "tests": [
    {
      "description": "current released spec version",
      "document": {
        "openbindings": "0.2.0",
        "operations": {}
      },
      "valid": true
    },
    {
      "description": "1.0.0 release version",
      "document": {
        "openbindings": "1.0.0",
        "operations": {}
      },
      "valid": true,
      "requiresSupports": "1.0.0"
    },
    {
      "description": "version with build metadata",
      "document": {
        "openbindings": "1.0.0+build.123",
        "operations": {}
      },
      "valid": true,
      "requiresSupports": "1.0.0"
    },
    {
      "description": "two-component version is not SemVer 2.0.0",
      "document": {
        "openbindings": "0.2",
        "operations": {}
      },
      "valid": false,
      "violates": [
        "OBI-D-12"
      ]
    },
    {
      "description": "four-component version is not SemVer 2.0.0",
      "document": {
        "openbindings": "0.2.0.0",
        "operations": {}
      },
      "valid": false,
      "violates": [
        "OBI-D-12"
      ]
    },
    {
      "description": "non-numeric version label",
      "document": {
        "openbindings": "latest",
        "operations": {}
      },
      "valid": false,
      "violates": [
        "OBI-D-12"
      ]
    },
    {
      "description": "version with v prefix",
      "document": {
        "openbindings": "v0.2.0",
        "operations": {}
      },
      "valid": false,
      "violates": [
        "OBI-D-12"
      ]
    },
    {
      "description": "empty string",
      "document": {
        "openbindings": "",
        "operations": {}
      },
      "valid": false,
      "violates": [
        "OBI-D-12"
      ]
    },
    {
      "description": "openbindings value is a number, not a string",
      "document": {
        "openbindings": 0.2,
        "operations": {}
      },
      "valid": false,
      "violates": [
        "OBI-D-12"
      ]
    },
    {
      "description": "openbindings value is null",
      "document": {
        "openbindings": null,
        "operations": {}
      },
      "valid": false,
      "violates": [
        "OBI-D-12"
      ]
    },
    {
      "description": "leading-zero pre-release identifier (forbidden by SemVer 2.0.0 §9)",
      "document": {
        "openbindings": "1.0.0-01",
        "operations": {}
      },
      "valid": false,
      "violates": [
        "OBI-D-12"
      ]
    }
  ]
}
