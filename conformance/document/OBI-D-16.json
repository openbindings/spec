{
  "rule": "OBI-D-16",
  "section": "14.2",
  "description": "Every schema $ref that is a same-document fragment resolves, from the OBI document root per section 10, to a location that exists within the document. Refs within a schema declaring its own $id are out of scope; absolute-URI $refs are external (evaluation-time).",
  "tests": [
    {
      "description": "same-document $ref resolving to a schemas-map entry",
      "document": {
        "openbindings": "0.2.0",
        "operations": {
          "getTask": {
            "output": {
              "$ref": "#/schemas/Task"
            }
          }
        },
        "schemas": {
          "Task": {
            "type": "object"
          }
        }
      },
      "valid": true
    },
    {
      "description": "bare # resolves to the document root",
      "document": {
        "openbindings": "0.2.0",
        "operations": {
          "echoDoc": {
            "output": {
              "$ref": "#"
            }
          }
        }
      },
      "valid": true
    },
    {
      "description": "dangling same-document $ref (missing schemas entry)",
      "document": {
        "openbindings": "0.2.0",
        "operations": {
          "getTask": {
            "output": {
              "$ref": "#/schemas/Missing"
            }
          }
        },
        "schemas": {
          "Task": {
            "type": "object"
          }
        }
      },
      "valid": false
    },
    {
      "description": "dangling nested subschema $ref",
      "document": {
        "openbindings": "0.2.0",
        "operations": {
          "listTasks": {
            "output": {
              "type": "array",
              "items": {
                "$ref": "#/schemas/Nope"
              }
            }
          }
        },
        "schemas": {}
      },
      "valid": false
    },
    {
      "description": "$ref under a nested $id is out of scope (resource-internal)",
      "document": {
        "openbindings": "0.2.0",
        "operations": {
          "getTask": {
            "output": {
              "$ref": "#/schemas/Task"
            }
          }
        },
        "schemas": {
          "Task": {
            "$id": "https://example.com/task.schema.json",
            "type": "object",
            "properties": {
              "parent": {
                "$ref": "#/$defs/base"
              }
            },
            "$defs": {
              "base": {
                "type": "string"
              }
            }
          }
        }
      },
      "valid": true
    },
    {
      "description": "external absolute $ref is not this rule's concern",
      "document": {
        "openbindings": "0.2.0",
        "operations": {
          "getTask": {
            "output": {
              "$ref": "https://example.com/schemas/task.json"
            }
          }
        }
      },
      "valid": true
    }
  ]
}
