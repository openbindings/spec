{
  "format": "openbindings.operation-graph@0.2.0",
  "kind": "execution",
  "description": "Error handling with onError: fetch an item's detail, falling back to a default value when the fetch fails. Mirrors the format spec's Example 7 (error path).",
  "fixtures": [
    {
      "id": "OG-EX-06",
      "name": "Error handling with onError (error path)",
      "section": "Normative examples / Example 7",
      "description": "One item's each invocation of items.get fails with TIMEOUT_EXCEEDED. Because this is a per-event failure and onError is set, the error event { error, event } is routed to the fallback transform, which reads event.id and error off the error event (event is the failed node's input value, distinct from $input) and produces a default record. That record reaches output.",
      "operations": {
        "items.get": {
          "responses": [
            {
              "whenInput": {
                "id": "item-1"
              },
              "fail": "TIMEOUT_EXCEEDED"
            }
          ]
        }
      },
      "graph": {
        "openbindings.operation-graph": "0.2.0",
        "nodes": {
          "in": {
            "type": "input"
          },
          "fetchDetail": {
            "type": "each",
            "operation": "items.get",
            "timeout": 5000,
            "onError": "fallback"
          },
          "fallback": {
            "type": "transform",
            "transform": "{ \"id\": event.id, \"name\": \"unknown\", \"error\": error }"
          },
          "out": {
            "type": "output"
          }
        },
        "edges": [
          {
            "from": "in",
            "to": "fetchDetail"
          },
          {
            "from": "fetchDetail",
            "to": "out"
          },
          {
            "from": "fallback",
            "to": "out"
          }
        ]
      },
      "writes": [
        {
          "id": "item-1"
        }
      ],
      "expected": {
        "output": [
          {
            "id": "item-1",
            "name": "unknown",
            "error": "TIMEOUT_EXCEEDED"
          }
        ],
        "ordering": "exact"
      }
    }
  ]
}
