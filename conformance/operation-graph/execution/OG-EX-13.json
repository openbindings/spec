{
  "format": "openbindings.operation-graph@0.2.0",
  "kind": "execution",
  "description": "The identity law: input -> operation(y) -> output is observationally indistinguishable from a direct invocation of y. These fixtures exercise the conformance anchor (the trivial wrapper, spec Example 1) across the invocation-conformance scenarios: unary, no-input (zero writes), client-streaming (multiple writes), and terminal error. Together they pin consequences 1, 2, and 4 of the law.",
  "fixtures": [
    {
      "id": "OG-EX-13",
      "name": "Identity wrapper, unary",
      "section": "Transparency (the identity law) / Example 1",
      "description": "The caller writes one value. The conduit pipes it into the held users.get invocation; the unary mock reads it, closes its input (closesAfter 1), and emits one result, which flows to output. One write in, one event out, exactly as direct invocation.",
      "operations": {
        "users.get": {
          "closesAfter": 1,
          "responses": [
            {
              "whenInput": {
                "id": "u1"
              },
              "emit": [
                {
                  "id": "u1",
                  "name": "Alice"
                }
              ]
            }
          ]
        }
      },
      "graph": {
        "openbindings.operation-graph": "0.2.0",
        "nodes": {
          "in": {
            "type": "input"
          },
          "get": {
            "type": "operation",
            "operation": "users.get"
          },
          "out": {
            "type": "output"
          }
        },
        "edges": [
          {
            "from": "in",
            "to": "get"
          },
          {
            "from": "get",
            "to": "out"
          }
        ]
      },
      "writes": [
        {
          "id": "u1"
        }
      ],
      "expected": {
        "output": [
          {
            "id": "u1",
            "name": "Alice"
          }
        ],
        "ordering": "exact"
      }
    },
    {
