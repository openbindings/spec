{
  "format": "openbindings.operation-graph@1",
  "kind": "validation",
  "description": "Well-formedness fixtures keyed to the stable OG-V-## validation-rule identifiers in the operation-graph format spec. valid:true graphs must validate against the op-graph JSON Schema; for schemaEnforced rules, valid:false graphs must be rejected by it. Negative graphs for non-schemaEnforced rules are otherwise schema-valid so that only the named rule is violated.",
  "notes": "OG-V-11 (operation and each nodes reference operations in the containing OBI) cannot be decided from a graph in isolation, so its tests carry an `operations` array for the verifier to resolve against. OG-V-14 requires every node's type to be one of the defined node types; unknown types are non-conformant and schema-enforced, so both the missing-type and unknown-type cases are fixtured as negatives.",
  "rules": [
    {
      "rule": "OG-V-01",
      "title": "The graph MUST declare an openbindings.operation-graph SemVer field.",
      "schemaEnforced": true,
      "tests": [
        {
          "description": "version present and valid",
          "graph": {
            "openbindings.operation-graph": "0.2.0",
            "nodes": {
              "in": {
                "type": "input"
              },
              "out": {
                "type": "output"
              }
            },
            "edges": [
              {
                "from": "in",
                "to": "out"
              }
            ]
          },
          "valid": true
        },
        {
          "description": "version field missing",
          "graph": {
            "nodes": {
              "in": {
                "type": "input"
              },
              "out": {
                "type": "output"
              }
            },
            "edges": [
              {
                "from": "in",
                "to": "out"
              }
            ]
          },
          "valid": false
        },
        {
          "description": "version is not a SemVer string",
          "graph": {
            "openbindings.operation-graph": "1",
            "nodes": {
              "in": {
                "type": "input"
              },
              "out": {
                "type": "output"
              }
            },
            "edges": [
              {
                "from": "in",
                "to": "out"
              }
            ]
          },
          "valid": false
        }
      ]
    },
    {
      "rule": "OG-V-02",
      "title": "The graph MUST contain exactly one input node.",
      "schemaEnforced": false,
      "tests": [
        {
          "description": "exactly one input node",
          "graph": {
            "openbindings.operation-graph": "0.2.0",
            "nodes": {
              "in": {
                "type": "input"
              },
              "out": {
                "type": "output"
              }
            },
            "edges": [
              {
                "from": "in",
                "to": "out"
              }
            ]
          },
          "valid": true
        },
        {
          "description": "two input nodes",
          "graph": {
            "openbindings.operation-graph": "0.2.0",
            "nodes": {
              "in": {
                "type": "input"
              },
              "in2": {
                "type": "input"
              },
              "out": {
                "type": "output"
              }
            },
            "edges": [
              {
                "from": "in",
                "to": "out"
              },
              {
                "from": "in2",
                "to": "out"
              }
            ]
          },
          "valid": false
        }
      ]
    },
    {
      "rule": "OG-V-03",
      "title": "The graph MUST contain exactly one output node.",
      "schemaEnforced": false,
      "tests": [
        {
          "description": "exactly one output node",
          "graph": {
            "openbindings.operation-graph": "0.2.0",
            "nodes": {
              "in": {
                "type": "input"
              },
              "out": {
                "type": "output"
              }
            },
            "edges": [
              {
                "from": "in",
                "to": "out"
              }
            ]
          },
          "valid": true
        },
        {
          "description": "two output nodes",
          "graph": {
            "openbindings.operation-graph": "0.2.0",
            "nodes": {
              "in": {
                "type": "input"
              },
              "out": {
                "type": "output"
              },
              "out2": {
                "type": "output"
              }
            },
            "edges": [
              {
                "from": "in",
                "to": "out"
              },
              {
                "from": "in",
                "to": "out2"
              }
            ]
          },
          "valid": false
        }
      ]
    },
    {
      "rule": "OG-V-04",
      "title": "The input node MUST NOT have incoming edges.",
      "schemaEnforced": false,
      "tests": [
        {
          "description": "input has no incoming edge",
          "graph": {
            "openbindings.operation-graph": "0.2.0",
            "nodes": {
              "in": {
                "type": "input"
              },
              "out": {
                "type": "output"
              }
            },
            "edges": [
              {
                "from": "in",
                "to": "out"
              }
            ]
          },
          "valid": true
        },
        {
          "description": "input is the target of an edge (the cycle carries an each node with maxIterations so only OG-V-04 is violated)",
          "graph": {
            "openbindings.operation-graph": "0.2.0",
            "nodes": {
              "in": {
                "type": "input"
              },
              "ea": {
                "type": "each",
                "operation": "x",
                "maxIterations": 3
              },
              "out": {
                "type": "output"
              }
            },
            "edges": [
              {
                "from": "in",
                "to": "ea"
              },
              {
                "from": "ea",
                "to": "in"
              },
              {
                "from": "in",
                "to": "out"
              }
            ]
          },
          "valid": false
        }
      ]
    },
    {
      "rule": "OG-V-05",
      "title": "The output node MUST NOT have outgoing edges.",
      "schemaEnforced": false,
      "tests": [
        {
          "description": "output has no outgoing edge",
          "graph": {
            "openbindings.operation-graph": "0.2.0",
            "nodes": {
              "in": {
                "type": "input"
              },
              "out": {
                "type": "output"
              }
            },
            "edges": [
              {
                "from": "in",
                "to": "out"
              }
            ]
          },
          "valid": true
        },
        {
          "description": "output is the source of an edge",
          "graph": {
            "openbindings.operation-graph": "0.2.0",
            "nodes": {
              "in": {
                "type": "input"
              },
              "out": {
                "type": "output"
              },
              "sink": {
                "type": "transform",
                "transform": "$"
              }
            },
            "edges": [
              {
                "from": "in",
                "to": "out"
              },
              {
                "from": "out",
                "to": "sink"
              }
            ]
          },
          "valid": false
        }
      ]
    },
    {
      "rule": "OG-V-06",
      "title": "Every node MUST be reachable from the input node (via edges and onError references).",
      "schemaEnforced": false,
      "tests": [
        {
          "description": "all nodes reachable",
          "graph": {
            "openbindings.operation-graph": "0.2.0",
            "nodes": {
              "in": {
                "type": "input"
              },
              "out": {
                "type": "output"
              }
            },
            "edges": [
              {
                "from": "in",
                "to": "out"
              }
            ]
          },
          "valid": true
        },
        {
          "description": "an onError target counts toward reachability",
          "graph": {
            "openbindings.operation-graph": "0.2.0",
            "nodes": {
              "in": {
                "type": "input"
              },
              "op": {
                "type": "operation",
                "operation": "x",
                "onError": "fb"
              },
              "fb": {
                "type": "transform",
                "transform": "$"
              },
              "out": {
                "type": "output"
              }
            },
            "edges": [
              {
                "from": "in",
                "to": "op"
              },
              {
                "from": "op",
                "to": "out"
              },
              {
                "from": "fb",
                "to": "out"
              }
            ]
          },
          "valid": true
        },
        {
          "description": "orphan node unreachable from input",
          "graph": {
            "openbindings.operation-graph": "0.2.0",
            "nodes": {
              "in": {
                "type": "input"
              },
              "out": {
                "type": "output"
              },
              "orphan": {
                "type": "transform",
                "transform": "$"
              }
            },
            "edges": [
              {
                "from": "in",
                "to": "out"
              }
            ]
          },
          "valid": false
        }
      ]
    },
    {
      "rule": "OG-V-07",
      "title": "Every edge MUST reference valid node keys in both from and to.",
      "schemaEnforced": false,
      "tests": [
        {
          "description": "all edge endpoints are real nodes",
          "graph": {
            "openbindings.operation-graph": "0.2.0",
            "nodes": {
              "in": {
                "type": "input"
              },
              "out": {
                "type": "output"
              }
            },
            "edges": [
              {
                "from": "in",
                "to": "out"
              }
            ]
          },
          "valid": true
        },
        {
          "description": "edge targets a nonexistent node key",
          "graph": {
            "openbindings.operation-graph": "0.2.0",
            "nodes": {
              "in": {
                "type": "input"
              },
              "out": {
                "type": "output"
              }
            },
            "edges": [
              {
                "from": "in",
                "to": "out"
              },
              {
                "from": "in",
                "to": "ghost"
              }
            ]
          },
          "valid": false
        }
      ]
    },
    {
      "rule": "OG-V-08",
      "title": "There MUST NOT be duplicate edges (same from and to pair).",
      "schemaEnforced": true,
      "tests": [
        {
          "description": "distinct edges",
          "graph": {
            "openbindings.operation-graph": "0.2.0",
            "nodes": {
              "in": {
                "type": "input"
              },
              "t": {
                "type": "transform",
                "transform": "$"
              },
              "out": {
                "type": "output"
              }
            },
            "edges": [
              {
                "from": "in",
                "to": "t"
              },
              {
                "from": "t",
                "to": "out"
              }
            ]
          },
          "valid": true
        },
        {
          "description": "an edge appears twice",
          "graph": {
            "openbindings.operation-graph": "0.2.0",
            "nodes": {
              "in": {
                "type": "input"
              },
              "out": {
                "type": "output"
              }
            },
            "edges": [
              {
                "from": "in",
                "to": "out"
              },
              {
                "from": "in",
                "to": "out"
              }
            ]
          },
          "valid": false
        }
      ]
    },
    {
      "rule": "OG-V-09",
      "title": "Every cycle MUST contain at least one each node with maxIterations declared (cycle detection follows data edges and onError references).",
      "schemaEnforced": false,
      "tests": [
        {
          "description": "cycle contains an each node with maxIterations",
          "graph": {
            "openbindings.operation-graph": "0.2.0",
            "nodes": {
              "in": {
                "type": "input"
              },
              "ea": {
                "type": "each",
                "operation": "x",
                "maxIterations": 5
              },
              "out": {
                "type": "output"
              }
            },
            "edges": [
              {
                "from": "in",
                "to": "ea"
              },
              {
                "from": "ea",
                "to": "ea"
              },
              {
                "from": "ea",
                "to": "out"
              }
            ]
          },
          "valid": true
        },
        {
          "description": "an each node bounding its own onError self-loop with maxIterations",
          "graph": {
            "openbindings.operation-graph": "0.2.0",
            "nodes": {
              "in": {
                "type": "input"
              },
              "ea": {
                "type": "each",
                "operation": "x",
                "maxIterations": 3,
                "onError": "ea"
              },
              "out": {
                "type": "output"
              }
            },
            "edges": [
              {
                "from": "in",
                "to": "ea"
              },
              {
                "from": "ea",
                "to": "out"
              }
            ]
          },
          "valid": true
        },
        {
          "description": "cycle of transforms with no bounded each node",
          "graph": {
            "openbindings.operation-graph": "0.2.0",
            "nodes": {
              "in": {
                "type": "input"
              },
              "a": {
                "type": "transform",
                "transform": "$"
              },
              "b": {
                "type": "transform",
                "transform": "$"
              },
              "out": {
                "type": "output"
              }
            },
            "edges": [
              {
                "from": "in",
                "to": "a"
              },
              {
                "from": "a",
                "to": "b"
              },
              {
                "from": "b",
                "to": "a"
              },
              {
                "from": "a",
                "to": "out"
              }
            ]
          },
          "valid": false
        },
        {
          "description": "cycle through an each node that does not declare maxIterations",
          "graph": {
            "openbindings.operation-graph": "0.2.0",
            "nodes": {
              "in": {
                "type": "input"
              },
              "ea": {
                "type": "each",
                "operation": "x"
              },
              "out": {
                "type": "output"
              }
            },
            "edges": [
              {
                "from": "in",
                "to": "ea"
              },
              {
                "from": "ea",
                "to": "ea"
              },
              {
                "from": "ea",
                "to": "out"
              }
            ]
          },
          "valid": false
        }
      ]
    },
    {
      "rule": "OG-V-10",
      "title": "operation nodes MUST NOT participate in any cycle (following data edges and onError references).",
      "schemaEnforced": false,
      "tests": [
        {
          "description": "an operation conduit on a straight path alongside a bounded each cycle",
          "graph": {
            "openbindings.operation-graph": "0.2.0",
            "nodes": {
              "in": {
                "type": "input"
              },
              "op": {
                "type": "operation",
                "operation": "x"
              },
              "ea": {
                "type": "each",
                "operation": "y",
                "maxIterations": 5
              },
              "out": {
                "type": "output"
              }
            },
            "edges": [
              {
                "from": "in",
                "to": "op"
              },
              {
                "from": "op",
                "to": "ea"
              },
              {
                "from": "ea",
                "to": "ea"
              },
              {
                "from": "ea",
                "to": "out"
              }
            ]
          },
          "valid": true
        },
        {
          "description": "an operation node on a data cycle (the cycle also carries a bounded each node, so only OG-V-10 is violated)",
          "graph": {
            "openbindings.operation-graph": "0.2.0",
            "nodes": {
              "in": {
                "type": "input"
              },
              "op": {
                "type": "operation",
                "operation": "x"
              },
              "ea": {
                "type": "each",
                "operation": "y",
                "maxIterations": 5
              },
              "out": {
                "type": "output"
              }
            },
            "edges": [
              {
                "from": "in",
                "to": "op"
              },
              {
                "from": "op",
                "to": "ea"
              },
              {
                "from": "ea",
                "to": "op"
              },
              {
                "from": "ea",
                "to": "out"
              }
            ]
          },
          "valid": false
        },
        {
          "description": "an operation node on a cycle closed by its own onError reference",
          "graph": {
            "openbindings.operation-graph": "0.2.0",
            "nodes": {
              "in": {
                "type": "input"
              },
              "op": {
                "type": "operation",
                "operation": "x",
                "onError": "retry"
              },
              "retry": {
                "type": "each",
                "operation": "y",
                "maxIterations": 3
              },
              "out": {
                "type": "output"
              }
            },
            "edges": [
              {
                "from": "in",
                "to": "op"
              },
              {
                "from": "op",
                "to": "out"
              },
              {
                "from": "retry",
                "to": "op"
              }
            ]
          },
          "valid": false
        }
      ]
    },
    {
      "rule": "OG-V-11",
      "title": "operation and each nodes MUST reference operations that exist in the containing OBI's operations map.",
      "schemaEnforced": false,
      "tests": [
        {
          "description": "all operation and each nodes resolve against the containing OBI's operations",
          "operations": [
            "items.fetch",
            "items.process"
          ],
          "graph": {
            "openbindings.operation-graph": "0.2.0",
            "nodes": {
              "in": {
                "type": "input"
              },
              "fetch": {
                "type": "operation",
                "operation": "items.fetch"
              },
              "process": {
                "type": "each",
                "operation": "items.process"
              },
              "out": {
                "type": "output"
              }
            },
            "edges": [
              {
                "from": "in",
                "to": "fetch"
              },
              {
                "from": "fetch",
                "to": "process"
              },
              {
                "from": "process",
                "to": "out"
              }
            ]
          },
          "valid": true
        },
        {
          "description": "an operation node references a key absent from the OBI's operations",
          "operations": [
            "items.fetch",
            "items.process"
          ],
          "graph": {
            "openbindings.operation-graph": "0.2.0",
            "nodes": {
              "in": {
                "type": "input"
              },
              "fetch": {
                "type": "operation",
                "operation": "items.fetch"
              },
              "process": {
                "type": "operation",
                "operation": "items.missing"
              },
              "out": {
                "type": "output"
              }
            },
            "edges": [
              {
                "from": "in",
                "to": "fetch"
              },
              {
                "from": "fetch",
                "to": "process"
              },
              {
                "from": "process",
                "to": "out"
              }
            ]
          },
          "valid": false
        },
        {
          "description": "an each node references a key absent from the OBI's operations",
          "operations": [
            "items.fetch"
          ],
          "graph": {
            "openbindings.operation-graph": "0.2.0",
            "nodes": {
              "in": {
                "type": "input"
              },
              "fetch": {
                "type": "each",
                "operation": "items.missing"
              },
              "out": {
                "type": "output"
              }
            },
            "edges": [
              {
                "from": "in",
                "to": "fetch"
              },
              {
                "from": "fetch",
                "to": "out"
              }
            ]
          },
          "valid": false
        },
        {
          "description": "a graph with no operation or each nodes resolves vacuously",
          "operations": [],
          "graph": {
            "openbindings.operation-graph": "0.2.0",
            "nodes": {
              "in": {
                "type": "input"
              },
              "out": {
                "type": "output"
              }
            },
            "edges": [
              {
                "from": "in",
                "to": "out"
              }
            ]
          },
          "valid": true
        },
        {
          "description": "an operation node against an EMPTY operations set is unresolvable (a direct binding invocation supplies no operations map; OG-V-11, §281)",
          "operations": [],
          "graph": {
            "openbindings.operation-graph": "0.2.0",
            "nodes": {
              "in": {
                "type": "input"
              },
              "call": {
                "type": "operation",
                "operation": "items.fetch"
              },
              "out": {
                "type": "output"
              }
            },
            "edges": [
              {
                "from": "in",
                "to": "call"
              },
              {
                "from": "call",
                "to": "out"
              }
            ]
          },
          "valid": false
        }
      ]
    },
    {
      "rule": "OG-V-12",
      "title": "filter nodes MUST have exactly one of schema or transform.",
      "schemaEnforced": true,
      "tests": [
        {
          "description": "filter with schema only",
          "graph": {
            "openbindings.operation-graph": "0.2.0",
            "nodes": {
              "in": {
                "type": "input"
              },
              "f": {
                "type": "filter",
                "schema": {
                  "required": [
                    "x"
                  ]
                }
              },
              "out": {
                "type": "output"
              }
            },
            "edges": [
              {
                "from": "in",
                "to": "f"
              },
              {
                "from": "f",
                "to": "out"
              }
            ]
          },
          "valid": true
        },
        {
          "description": "filter with transform only",
          "graph": {
            "openbindings.operation-graph": "0.2.0",
            "nodes": {
              "in": {
                "type": "input"
              },
              "f": {
                "type": "filter",
                "transform": "true"
              },
              "out": {
                "type": "output"
              }
            },
            "edges": [
              {
                "from": "in",
                "to": "f"
              },
              {
                "from": "f",
                "to": "out"
              }
            ]
          },
          "valid": true
        },
        {
          "description": "filter with both schema and transform",
          "graph": {
            "openbindings.operation-graph": "0.2.0",
            "nodes": {
              "in": {
                "type": "input"
              },
              "f": {
                "type": "filter",
                "schema": {
                  "required": [
                    "x"
                  ]
                },
                "transform": "true"
              },
              "out": {
                "type": "output"
              }
            },
            "edges": [
              {
                "from": "in",
                "to": "f"
              },
              {
                "from": "f",
                "to": "out"
              }
            ]
          },
          "valid": false
        },
        {
          "description": "filter with neither schema nor transform",
          "graph": {
            "openbindings.operation-graph": "0.2.0",
            "nodes": {
              "in": {
                "type": "input"
              },
              "f": {
                "type": "filter"
              },
              "out": {
                "type": "output"
              }
            },
            "edges": [
              {
                "from": "in",
                "to": "f"
              },
              {
                "from": "f",
                "to": "out"
              }
            ]
          },
          "valid": false
        }
      ]
    },
    {
      "rule": "OG-V-13",
      "title": "buffer nodes MUST NOT have both until and through.",
      "schemaEnforced": true,
      "tests": [
        {
          "description": "buffer with until only",
          "graph": {
            "openbindings.operation-graph": "0.2.0",
            "nodes": {
              "in": {
                "type": "input"
              },
              "b": {
