{
  "format": "openbindings.core-tool-scenarios@1",
  "rule": "OBI-T-11",
  "section": "10.3",
  "description": "Reference-cycle scenarios require termination while preserving the rule's permitted success-or-error handling.",
  "scenarios": [
    {
      "id": "T11-S-01",
      "description": "A direct two-schema reference cycle terminates; the implementation may resolve it or report a resolver error.",
      "action": "resolve-schema-cycle",
      "given": {
        "document": {
          "openbindings": "0.2.0",
          "operations": { "cycle": { "input": { "$ref": "#/schemas/A" } } },
          "schemas": {
            "A": { "$ref": "#/schemas/B" },
            "B": { "$ref": "#/schemas/A" }
          }
        },
        "operation": "cycle",
        "side": "input",
        "value": null
      },
      "expected": {
        "terminates": true,
        "allowedOutcomes": ["valid", "resolver-error"]
      }
    },
    {
      "id": "T11-S-02",
      "description": "A productive recursive object schema terminates on a finite mismatching value.",
      "action": "resolve-schema-cycle",
      "given": {
        "document": {
          "openbindings": "0.2.0",
          "operations": { "walk": { "input": { "$ref": "#/schemas/Node" } } },
          "schemas": {
            "Node": {
              "type": "object",
              "required": ["value"],
              "properties": {
                "value": { "type": "string" },
                "next": { "$ref": "#/schemas/Node" }
              }
            }
          }
        },
        "operation": "walk",
        "side": "input",
        "value": { "value": "root", "next": { "value": 7 } }
      },
      "expected": {
        "terminates": true,
        "allowedOutcomes": ["instance-mismatch", "resolver-error"]
      }
    }
  ]
}
