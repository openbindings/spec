{
  "kind": "agree",
  "language": "jsonata",
  "expectedEngine": "jsonata-js@2.1.1",
  "description": "Portable transform subset: expressions both jsonata-js (normative) and jsonata-go v1.5.4 evaluate identically. This is the cross-SDK GATE.",
  "cases": [
    {
      "id": "root-id-obj",
      "description": "identity $ on object",
      "expr": "$",
      "input": {
        "merged": true
      },
      "expected": {
        "status": "value",
        "value": {
          "merged": true
        }
      }
    },
    {
      "id": "root-id-arr",
      "description": "identity $ on array",
      "expr": "$",
      "input": [
        1,
        2,
        3
      ],
      "expected": {
        "status": "value",
        "value": [
          1,
          2,
          3
        ]
      }
    },
    {
      "id": "root-input-var",
      "description": "unbound $input var",
      "expr": "$input",
      "input": {
        "input": "x"
      },
      "expected": {
        "status": "undefined"
      }
    },
    {
      "id": "path-deep-scalar",
      "description": "deep path to scalar",
      "expr": "a.b.c",
      "input": {
        "a": {
          "b": {
            "c": 5
          }
        }
      },
      "expected": {
        "status": "value",
        "value": 5
      }
    },
    {
      "id": "path-seq",
