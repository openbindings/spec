      "expected": {
        "status": "value",
        "value": {
          "obi": "x.obi.json",
          "operation": "users.get",
          "binding": "users.get.openapi",
          "format": "json"
        }
      }
    },
    {
      "id": "obp-16-op-format",
      "description": "op mapper",
      "expr": "{\"obi\": $$.interface, \"operation\": $$.operation, \"format\": \"json\"}",
      "input": {
        "interface": "x.obi.json",
        "operation": "users.get"
