{
  "kind": "agree",
  "language": "jsonata",
  "expectedEngine": "jsonata-js@2.1.1",
  "description": "Every distinct JSONata transform shipped in ob's own OBIs (ob.obi.json, ob.bound.obi.json, serve.obi.json, demo) \u2014 the CLI machine-lane arg mappers. All agree across both engines; this pins that guarantee.",
  "cases": [
    {
      "id": "obp-01-sift-merge",
      "description": "serve source-add machine lane",
      "expr": "$merge([$sift($$, function($v, $k) { $k != \"bindingSpec\" }), $exists($$.bindingSpec) ? {\"binding-spec\": $$.bindingSpec} : {}, {\"format\": \"json\"}])",
      "input": {
        "interface": "x.obi.json",
        "bindingSpec": "openapi"
      },
      "expected": {
        "status": "value",
        "value": {
          "interface": "x.obi.json",
          "binding-spec": "openapi",
          "format": "json"
        }
      }
    },
    {
      "id": "obp-02-type-merge",
      "description": "common object passthrough (10x)",
      "expr": "$merge([$type($$) = \"object\" ? $$ : {}, {\"format\": \"json\"}])",
      "input": {
        "interface": "x.obi.json",
        "operation": "users.get"
      },
      "expected": {
        "status": "value",
        "value": {
          "interface": "x.obi.json",
          "operation": "users.get",
          "format": "json"
        }
      }
    },
    {
      "id": "obp-03-url-value",
      "description": "kv url+value merge",
      "expr": "$merge([{ \"url\": key }, value])",
      "input": {
        "key": "https://example.com",
        "value": {
          "a": 1,
          "b": 2
        }
      },
      "expected": {
        "status": "value",
        "value": {
          "url": "https://example.com",
          "a": 1,
          "b": 2
        }
      }
    },
    {
      "id": "obp-04-op-add",
      "description": "operation add mapper",
      "expr": "$merge([{\"obi-path\": $$.interface, \"key\": $$.key, \"description\": $$.description, \"alias\": $$.aliases, \"tag\": $$.tags, \"input-schema\": $$.input, \"output-schema\": $$.output}, $exists($$.idempotent) ? {\"idempotent\": $string($$.idempotent)} : {}])",
      "input": {
        "interface": "x.obi.json",
        "key": "op1",
        "description": "d",
        "aliases": [
          "a"
        ],
        "tags": [
          "t"
        ],
        "input": {
          "type": "object"
        },
        "output": {
          "type": "string"
        },
        "idempotent": true
      },
      "expected": {
        "status": "value",
        "value": {
          "obi-path": "x.obi.json",
          "key": "op1",
          "description": "d",
          "alias": [
            "a"
          ],
          "tag": [
            "t"
          ],
          "input-schema": {
            "type": "object"
          },
          "output-schema": {
            "type": "string"
          },
          "idempotent": "true"
        }
      }
    },
    {
      "id": "obp-05-op-update",
      "description": "operation update mapper",
      "expr": "$merge([{\"obi-path\": $$.interface, \"operation\": $$.operation, \"description\": $$.description, \"input-schema\": $$.input, \"output-schema\": $$.output, \"add-tag\": $$.addTags, \"remove-tag\": $$.removeTags, \"own\": $$.own}, $exists($$.idempotent) ? {\"idempotent\": $string($$.idempotent)} : {}, $exists($$.deprecated) ? {\"deprecated\": $string($$.deprecated)} : {}])",
      "input": {
        "interface": "x.obi.json",
        "operation": "users.get",
        "description": "d",
        "input": {
          "type": "object"
        },
        "output": {
          "type": "string"
        },
        "addTags": [
          "a"
        ],
        "removeTags": [
          "b"
        ],
        "own": true,
        "idempotent": false,
        "deprecated": true
      },
      "expected": {
        "status": "value",
        "value": {
          "obi-path": "x.obi.json",
          "operation": "users.get",
          "description": "d",
          "input-schema": {
            "type": "object"
          },
          "output-schema": {
            "type": "string"
          },
          "add-tag": [
            "a"
          ],
          "remove-tag": [
            "b"
          ],
          "own": true,
          "idempotent": "false",
          "deprecated": "true"
        }
      }
    },
    {
      "id": "obp-06-source-add",
      "description": "source add nested mapper",
      "expr": "$merge([{\"obi-path\": $$.interface, \"source\": $$.source.bindingSpec & \":\" & $$.source.location, \"key\": $$.source.name, \"uri\": $$.source.outputLocation, \"description\": $$.source.description, \"yes\": true}, $$.source.embed ? {\"resolve\": \"content\"} : {}])",
      "input": {
        "interface": "x.obi.json",
        "source": {
          "bindingSpec": "openapi",
          "location": "https://ex.com/o.json",
          "name": "s1",
          "outputLocation": "out.json",
          "description": "d",
          "embed": true
        }
      },
      "expected": {
        "status": "value",
        "value": {
          "obi-path": "x.obi.json",
          "source": "openapi:https://ex.com/o.json",
          "key": "s1",
          "uri": "out.json",
          "description": "d",
          "yes": true,
          "resolve": "content"
        }
      }
    },
    {
      "id": "obp-07-correlate",
      "description": "demo correlation predicate",
      "expr": "place != null and subscribe != null and subscribe.orderId = place.orderId and subscribe.status in ['ready', 'picked_up']",
      "input": {
        "place": {
          "orderId": "o1"
        },
        "subscribe": {
          "orderId": "o1",
          "status": "ready"
        }
      },
      "expected": {
        "status": "value",
        "value": true
      }
    },
    {
      "id": "obp-08-subscribe-field",
      "description": "bare field-ref to object",
      "expr": "subscribe",
      "input": {
        "subscribe": {
          "orderId": "o1",
          "status": "ready"
        }
      },
      "expected": {
        "status": "value",
        "value": {
          "orderId": "o1",
          "status": "ready"
        }
      }
    },
    {
      "id": "obp-09-input-string",
      "description": "wrap input as string (4x)",
      "expr": "{ \"input\": $string($$) }",
      "input": {
        "a": 1,
        "b": [
          2,
          3
        ]
      },
      "expected": {
        "status": "value",
        "value": {
          "input": "{\"a\":1,\"b\":[2,3]}"
        }
      }
    },
    {
      "id": "obp-10-url-key",
      "description": "url from key",
      "expr": "{ \"url\": key }",
      "input": {
        "key": "https://example.com/a"
      },
      "expected": {
        "status": "value",
        "value": {
          "url": "https://example.com/a"
        }
      }
    },
    {
      "id": "obp-11-compare",
      "description": "compare mapper",
      "expr": "{\"baseline\": $$.baseline, \"comparison\": $$.comparison, \"from-sources\": $$.fromSources, \"only\": $$.only, \"format\": \"json\"}",
      "input": {
        "baseline": "b.json",
        "comparison": "c.json",
        "fromSources": [
          "s1"
        ],
        "only": [
          "op1"
        ]
      },
      "expected": {
        "status": "value",
        "value": {
          "baseline": "b.json",
          "comparison": "c.json",
          "from-sources": [
            "s1"
          ],
          "only": [
            "op1"
          ],
          "format": "json"
        }
      }
    },
    {
      "id": "obp-12-binding-spec",
      "description": "binding-spec mapper",
      "expr": "{\"binding-spec\": $$.bindingSpec, \"format\": \"json\"}",
      "input": {
        "bindingSpec": "openapi"
      },
      "expected": {
        "status": "value",
        "value": {
          "binding-spec": "openapi",
          "format": "json"
        }
      }
    },
    {
      "id": "obp-13-migrate",
      "description": "migrate mapper",
      "expr": "{\"interface\": $$.interface, \"target-obi\": $$.target, \"dry-run\": $$.dryRun, \"yes\": true, \"format\": \"json\"}",
      "input": {
        "interface": "x.obi.json",
        "target": "y.obi.json",
        "dryRun": true
      },
      "expected": {
        "status": "value",
        "value": {
          "interface": "x.obi.json",
          "target-obi": "y.obi.json",
          "dry-run": true,
          "yes": true,
          "format": "json"
        }
      }
    },
    {
      "id": "obp-14-validate",
      "description": "validate mapper",
      "expr": "{\"locator\": $$.interface, \"strict\": $$.strict, \"format\": \"json\"}",
      "input": {
        "interface": "x.obi.json",
        "strict": true
      },
      "expected": {
        "status": "value",
        "value": {
          "locator": "x.obi.json",
          "strict": true,
          "format": "json"
        }
      }
    },
    {
      "id": "obp-15-binding-op",
      "description": "binding-scoped mapper",
      "expr": "{\"obi\": $$.interface, \"operation\": $$.operation, \"binding\": $$.binding, \"format\": \"json\"}",
      "input": {
        "interface": "x.obi.json",
        "operation": "users.get",
        "binding": "users.get.openapi"
