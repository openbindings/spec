{
    "openbindings": "0.1.0",
    "name": "OpenBindings Binding Executor",
    "version": "0.1.0",
    "description": "Interface for executing bindings in specific formats. A binding executor interprets a binding format (e.g., OpenAPI, AsyncAPI, gRPC, MCP) and knows how to execute operations through it. executeBinding always returns a stream of events — unary calls produce one event, streaming calls produce many.",
    "schemas": {
        "FormatInfo": {
            "type": "object",
            "description": "Information about a supported binding format.",
            "properties": {
                "token": {
                    "type": "string",
                    "description": "Format token (e.g., openapi@3.1, asyncapi@3.0, grpc)."
                },
                "description": {
                    "type": "string",
                    "description": "Human-readable description of this format."
                }
            },
            "required": ["token"]
        },
        "ExecuteSource": {
            "type": "object",
            "description": "Binding source for execution.",
            "properties": {
                "format": {
                    "type": "string",
                    "description": "Format token."
                },
                "location": {
                    "type": "string",
                    "description": "Location of the binding source (path or URL)."
                },
                "content": {
                    "description": "Binding source content directly."
                }
            },
            "required": ["format"],
            "oneOf": [
                { "required": ["location"] },
                { "required": ["content"] }
            ],
            "additionalProperties": false
        },
        "BindingContext": {
            "type": "object",
            "description": "Opaque runtime context for binding execution. Well-known fields include 'bearerToken', 'apiKey', 'basic'.",
            "additionalProperties": true
        },
        "ExecutionOptions": {
            "type": "object",
            "description": "Developer-supplied per-request execution options.",
            "properties": {
                "headers": {
                    "type": "object",
                    "additionalProperties": { "type": "string" }
                },
                "cookies": {
                    "type": "object",
                    "additionalProperties": { "type": "string" }
                },
                "environment": {
                    "type": "object",
                    "additionalProperties": { "type": "string" }
                },
                "metadata": {
                    "type": "object",
                    "additionalProperties": true
                }
            },
            "additionalProperties": false
        },
        "ExecuteBindingInput": {
            "type": "object",
            "description": "Input for executing a resolved binding.",
            "properties": {
                "source": {
                    "$ref": "#/schemas/ExecuteSource"
                },
                "ref": {
                    "type": "string",
                    "description": "Reference within the binding source."
                },
                "input": {
                    "description": "Operation input data."
                },
                "context": {
                    "$ref": "#/schemas/BindingContext"
                },
                "options": {
                    "$ref": "#/schemas/ExecutionOptions"
                }
            },
            "required": ["source", "ref"],
            "additionalProperties": false
        },
        "Error": {
            "type": "object",
            "properties": {
                "code": { "type": "string" },
                "message": { "type": "string" },
                "details": {}
            },
            "required": ["code", "message"]
        },
        "ExecuteBindingOutput": {
            "type": "object",
            "description": "Output from executing a resolved binding.",
            "properties": {
                "output": {},
                "status": { "type": "integer" },
                "durationMs": { "type": "number" },
                "error": { "$ref": "#/schemas/Error" }
            },
            "additionalProperties": true
        }
    },
    "operations": {
        "listFormats": {
            "description": "List binding formats this executor supports.",
            "idempotent": true,
            "output": {
                "type": "array",
                "items": { "$ref": "#/schemas/FormatInfo" }
            }
        },
        "executeBinding": {
            "description": "Execute a resolved binding. Returns a stream of events — unary calls produce one event, streaming calls produce many until the connection closes.",
            "input": { "$ref": "#/schemas/ExecuteBindingInput" },
            "output": { "$ref": "#/schemas/ExecuteBindingOutput" }
        }
    }
}
