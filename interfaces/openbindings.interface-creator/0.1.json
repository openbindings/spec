{
    "openbindings": "0.2.0",
    "name": "OpenBindings Interface Creator",
    "version": "0.1.0",
    "description": "Interface for creating OpenBindings interfaces from binding artifacts. Given a binding specification (e.g., an OpenAPI spec), an interface creator extracts operations, schemas, sources, and bindings into an OBI document.",
    "schemas": {
        "FormatInfo": {
            "type": "object",
            "description": "Information about a supported binding format.",
            "properties": {
                "token": {
                    "type": "string",
                    "description": "Format token (e.g., openapi@3.1, asyncapi@3.0, grpc)."
                },
                "description": {
                    "type": "string",
                    "description": "Human-readable description of this format."
                }
            },
            "required": ["token"]
        },
        "CreateInterfaceSource": {
            "type": "object",
            "description": "A binding source to create an interface from.",
            "properties": {
                "format": {
                    "type": "string",
                    "description": "Format token for this source."
                },
                "name": {
                    "type": "string",
                    "description": "Key name for this binding source in the output."
                },
                "location": {
                    "type": "string",
                    "description": "Location to fetch content from (path or URL)."
                },
                "content": {
                    "description": "Content provided directly."
                },
                "outputLocation": {
                    "type": "string",
                    "description": "Location to reference in the output."
                },
                "embed": {
                    "type": "boolean",
                    "description": "If true, embed content inline in the output."
                },
                "description": {
                    "type": "string",
                    "description": "Human-readable description for this source."
                }
            },
            "required": ["format"],
            "oneOf": [
                { "required": ["location"] },
                { "required": ["content"] }
            ],
            "additionalProperties": false
        },
        "CreateInterfaceInput": {
            "type": "object",
            "properties": {
                "openbindingsVersion": {
                    "type": "string",
                    "description": "Target OpenBindings spec version."
                },
                "sources": {
                    "type": "array",
                    "items": { "$ref": "#/schemas/CreateInterfaceSource" },
                    "description": "Binding sources to create from."
                },
                "name": {
                    "type": "string",
                    "description": "Interface name override."
                },
                "version": {
                    "type": "string",
                    "description": "Interface contract version override."
                },
                "description": {
                    "type": "string",
                    "description": "Interface description override."
                }
            },
            "additionalProperties": false
        },
        "OpenBindingsInterface": {
            "type": "object",
            "description": "A valid OpenBindings interface document.",
            "additionalProperties": true
        }
    },
    "operations": {
        "listFormats": {
            "description": "List binding formats this creator can produce interfaces from.",
            "idempotent": true,
            "output": {
                "type": "array",
                "items": { "$ref": "#/schemas/FormatInfo" }
            }
        },
        "createInterface": {
            "description": "Create an OpenBindings interface, optionally from binding source artifacts.",
            "idempotent": true,
            "input": { "$ref": "#/schemas/CreateInterfaceInput" },
            "output": { "$ref": "#/schemas/OpenBindingsInterface" }
        }
    }
}
