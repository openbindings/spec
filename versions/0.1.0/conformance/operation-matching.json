      "candidate": {
        "operations": {
          "task.create": {
            "input": {
              "type": "object"
            }
          }
        }
      },
      "result": {
        "compatible": false,
        "operations": {
          "task.create": {
            "match": "primary_key",
            "input": "compatible"
          },
          "task.delete": {
            "match": "missing"
          }
        }
      }
